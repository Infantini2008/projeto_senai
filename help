# 1. Cria o ambiente virtual

python -m venv .venv

# 2. ATIVA o ambiente virtual (PASSO MAIS IMPORTANTE)

.\.venv\Scripts\activate
(Se erro: Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope Process)

# 3. Instala todas as dependências de uma vez

pip install -r requirements.txt

# 4. (Opcional) Se o requirements estiver desatualizado, instale os principais:

pip install python-dotenv psycopg2-binary Flask flask-cors Flask-Login

# 5. Testa a conexão com o banco de dados

python database.py

# 6. Se o banco conectou, sobe a API

python app.py

OBS: Criar Arquivo .env e colocar: DB_URL = postgres://avnadmin:AVNS_T6QHOhUgvDRVXGUQXLA@pg-174877d1-app-consumo.d.aivencloud.com:17956/defaultdb?sslmode=require
